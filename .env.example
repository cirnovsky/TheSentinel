# OpenAI API key used by Codex/OpenAI SDK calls.
OPENAI_API_KEY="sk-your-openai-key"

# Optional: force model choice for generation features.
OPENAI_MODEL="gpt-4.1"

# Optional: override OpenAI API base URL (useful behind proxies/gateways).
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional: application URL for callbacks or self links.
APP_URL="http://localhost:3000"
